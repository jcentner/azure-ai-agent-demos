# Azure AI Foundry project endpoint
# Format: https://<resource-name>.services.ai.azure.com/api/projects/<project-name>
# Find this in Azure AI Foundry portal → Project → Overview → Libraries → Foundry
PROJECT_ENDPOINT=

# Model deployment name (e.g., gpt-4.1, gpt-4.1-mini)
MODEL_DEPLOYMENT_NAME=

# Agent name (creates new agent if not exists)
AGENT_NAME=mcp-local-chinook-demo

# --- MCP Server Config ---

# Local MCP server port and path
PORT=8787
MCP_PATH=/mcp

# Server DB paths (relative to mcp_local_server_agent/)
DB_BASE_PATH=server/db/chinook.db
DB_WORKING_DIR=server/db/working

# Persist working copy changes between restarts (true/false)
PERSIST_WORKING_COPY=false

# Optional: Bearer token for MCP server auth (recommended if exposing via ngrok)
# LOCAL_MCP_TOKEN=your-demo-token

# --- Azure Agent Config ---

# MCP server URL: Set once ngrok is running (e.g., https://<sub>.ngrok.app/mcp)
# Must be publicly reachable — Azure agent service cannot reach localhost
# MCP_SERVER_URL=

# Optional: Name of the Foundry project connection that stores the MCP bearer token
# Create a Custom connection in the Foundry portal with your LOCAL_MCP_TOKEN value
# If not set, MCP calls will not include auth headers
# MCP_CONNECTION_NAME=
