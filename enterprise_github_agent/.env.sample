# Azure AI Foundry project endpoint
# Format: https://<resource-name>.services.ai.azure.com/api/projects/<project-name>
# Find this in Azure AI Foundry portal → Project → Overview → Libraries → Foundry
PROJECT_ENDPOINT=

# Model deployment name (e.g., gpt-5.2, gpt-4o)
MODEL_DEPLOYMENT_NAME=gpt-5.2

# Agent name (creates new agent if not exists)
AGENT_NAME=enterprise-github-agent

# GitHub Personal Access Token
# Create at: https://github.com/settings/tokens
# Required scopes: repo (Full control of private repositories)
# For issues/PRs: also enable 'issues' and 'pull_requests' if using fine-grained tokens
GITHUB_PAT=

# Optional: Default repository for the demo (owner/repo format)
# If set, the agent will suggest prompts using this repo
# GITHUB_REPO=your-username/test-repo
